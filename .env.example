BOT_TOKEN=YOUR_BOT_TOKEN
BOT_USERNAME=HowToSeeWorld_bot
CHANNEL_USERNAME=HowTooSeeWorld
CHANNEL_LINK=https://t.me/HowTooSeeWorld
BRAND_NAME=HowTooSee | Premium VPN

# PostgreSQL database. Replace password with your real value.
DATABASE_URL=postgresql+asyncpg://pasarguard_telegram_bot:YOUR_STRONG_PASSWORD@127.0.0.1:5432/pasarguard_telegram_bot

SUBSCRIPTION_BASE_URL=https://example.com/sub
REFERRAL_COMMISSION_PERCENT=10
REFERRED_DISCOUNT_PERCENT=5
FREE_TEST_MB=150
WALLET_MIN_TOPUP=50000
SERVICE_NAME_PREFIX=howtosee_

# Comma or space separated Telegram chat IDs. These become super admins.
ADMIN_CHAT_IDS=6413811117

# Pasarguard integration - Phase 4
PASARGUARD_ENABLED=false
PASARGUARD_BASE_URL=https://docdev.pangshanbebazar.ir:2087
PASARGUARD_ADMIN_USERNAME=YOUR_PASARGUARD_ADMIN
PASARGUARD_ADMIN_PASSWORD=YOUR_PASARGUARD_PASSWORD
PASARGUARD_TIMEOUT_SECONDS=20
PASARGUARD_VERIFY_SSL=true
# Keep true while testing. Template apply buttons can still force a real sync after numeric confirmation.
PASARGUARD_DRY_RUN=true
PASARGUARD_MANAGED_PREFIX=HTS_BOT
# Required before real template creation. Use Pasarguard group IDs for users/templates created by the bot.
PASARGUARD_TEMPLATE_GROUP_IDS=1
PASARGUARD_USERNAME_PREFIX=hts_
PASARGUARD_USERNAME_SUFFIX=
